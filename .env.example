# ── Backblaze B2 ────────────────────────────────────────────────
# Ve a https://www.backblaze.com/b2/cloud-storage.html
# Crea una cuenta gratis → B2 Cloud Storage → Buckets
# Luego: App Keys → Add a New Application Key
#
# B2_KEY_ID      = "K00xxxxxxxxxxxxxx"
# B2_APP_KEY     = "K00xxxxxxxxxxxxxx"
# B2_ENDPOINT    = "s3.us-west-004.backblazeb2.com"
#                ↑ este aparece en el detalle del bucket
# B2_BUCKET_NAME = "renombot-sis"   (nombre que le pongas al bucket)

B2_KEY_ID=
B2_APP_KEY=
B2_ENDPOINT=
B2_BUCKET_NAME=renombot-sis

# ── Railway ────────────────────────────────────────────────────
# PORT se setea automáticamente en Railway
PORT=5000

# ── Tunables opcionales ────────────────────────────────────────
# MAX_UPLOAD_MB      Límite de tamaño total por request (default: 500)
# MAX_FILE_MB        Límite por archivo individual dentro de un ZIP (default: 500)
# MAX_JOBS           Máximo de jobs simultáneos (default: 5)
# JOB_TTL_SEC        Segundos antes de purgar un job inactivo (default: 3600)
# ZIP_COMPRESS_LEVEL Nivel de compresión ZIP 0-9 (default: 6)
# LOG_QUEUE_SIZE     Máximo de mensajes en cola por job (default: 2000)
# SSE_TIMEOUT_SEC    Segundos de espera por mensaje antes de heartbeat (default: 20)
# LOG_LEVEL          INFO | DEBUG | WARNING | ERROR (default: INFO)
